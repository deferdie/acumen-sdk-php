{
    "name": "acumenlogs/php-sdk",
    "description": "Acumen Logs monitoring SDK for PHP/Laravel",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/http": "^10.0|^11.0",
        "illuminate/bus": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "AcumenLogs\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AcumenLogs\\AcumenLogsServiceProvider"
            ],
            "aliases": {
                "AcumenLogs": "AcumenLogs\\Facades\\AcumenLogs"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
